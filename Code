<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Roll & Rise</title>
    <style>
        :root {
            --primary-bg: #1a1a2e;
            --accent-color: #e94560;
            --text-color: #ffffff;
            --tile-light: #dff5e1;
            --tile-dark: #fff6d6;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: var(--primary-bg);
            color: var(--text-color);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
        }

        /* --- STARTING INTERFACE (STRICTLY PRESERVED) --- */
        #start-screen {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 100;
            transition: opacity 0.5s ease;
        }

        .title-container {
            text-align: center;
            margin-bottom: 2rem;
            animation: fadeInDown 1s ease-out;
        }

        h1 {
            font-size: 5rem;
            color: var(--accent-color);
            text-transform: uppercase;
            letter-spacing: 5px;
            text-shadow: 0 0 20px rgba(233, 69, 96, 0.5);
            margin-bottom: 0.5rem;
        }

        .quote {
            font-style: italic;
            font-size: 1.2rem;
            color: #95a5a6;
            letter-spacing: 2px;
        }

        #start-btn {
            padding: 1.2rem 3.5rem;
            font-size: 1.5rem;
            font-weight: bold;
            background-color: var(--accent-color);
            color: white;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(233, 69, 96, 0.4);
            animation: pulse 2s infinite;
        }

        #start-btn:hover {
            transform: scale(1.1);
            box-shadow: 0 8px 25px rgba(233, 69, 96, 0.6);
        }

        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-50px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }

        /* --- GAME INTERFACE --- */
        #game-container {
            display: none;
            flex-direction: column;
            align-items: center;
            width: 100%;
            height: 100%;
            padding: 10px;
        }

        canvas {
            background: white;
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .controls {
            width: 100%;
            max-width: 600px;
            height: 140px;
            display: flex;
            justify-content: space-around;
            align-items: center;
            padding: 10px;
            background: rgba(255,255,255,0.05);
            border-radius: 15px;
            margin-top: 10px;
        }

        .player-info {
            text-align: center;
            min-width: 100px;
        }

        .player-card {
            padding: 10px;
            border-radius: 8px;
            transition: all 0.3s;
            border: 2px solid transparent;
        }

        .player-card.active {
            border-color: var(--accent-color);
            background: rgba(233, 69, 96, 0.1);
            transform: translateY(-5px);
        }

        .token-preview {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            margin: 5px auto;
            border: 2px solid white;
        }

        .dice-area {
            text-align: center;
        }

        #roll-btn {
            background: #27ae60;
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            font-size: 1.1rem;
            margin-bottom: 8px;
        }

        #roll-btn:disabled {
            background: #7f8c8d;
            cursor: not-allowed;
        }

        .dice-display {
            width: 60px;
            height: 60px;
            background: white;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto;
            position: relative;
            box-shadow: inset 0 0 10px rgba(0,0,0,0.2);
        }

        .dot {
            width: 10px;
            height: 10px;
            background: #333;
            border-radius: 50%;
            position: absolute;
        }

        /* Message Overlay */
        #game-msg {
            position: fixed;
            top: 20%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(233, 69, 96, 0.95);
            padding: 15px 30px;
            border-radius: 50px;
            font-weight: bold;
            font-size: 1.5rem;
            display: none;
            z-index: 200;
            pointer-events: none;
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
            animation: popIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        @keyframes popIn {
            0% { transform: translate(-50%, -50%) scale(0); }
            100% { transform: translate(-50%, -50%) scale(1); }
        }
    </style>
</head>
<body>

    <div id="start-screen">
        <div class="title-container">
            <h1>Roll & Rise</h1>
            <p class="quote">Climb High, Avoid the Fall</p>
        </div>
        <button id="start-btn">START GAME</button>
    </div>

    <div id="game-container">
        <canvas id="gameCanvas"></canvas>
        <div id="game-msg"></div>
        <div class="controls">
            <div class="player-info">
                <div id="p1-card" class="player-card active">
                    <div>Player 1</div>
                    <div class="token-preview" style="background: #ff4d4d;"></div>
                </div>
            </div>

            <div class="dice-area">
                <button id="roll-btn">ROLL DICE</button>
                <div id="dice" class="dice-display">
                    <!-- Dots will be added by JS -->
                </div>
            </div>

            <div class="player-info">
                <div id="p2-card" class="player-card">
                    <div>Player 2</div>
                    <div class="token-preview" style="background: #4d94ff;"></div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const startScreen = document.getElementById('start-screen');
        const startBtn = document.getElementById('start-btn');
        const gameContainer = document.getElementById('game-container');
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const rollBtn = document.getElementById('roll-btn');
        const diceDisplay = document.getElementById('dice');
        const gameMsg = document.getElementById('game-msg');

        // Sounds
        const diceSound = new Audio("https://www.soundjay.com/misc/sounds/dice-roll-1.mp3");

        // Game Configuration
        const gridSize = 10;
        let tileSize = 0;
        let currentPlayer = 0;
        let isMoving = false;

        const players = [
            { pos: 1, color: '#ff4d4d', name: 'Player 1', targetPos: 1 },
            { pos: 1, color: '#4d94ff', name: 'Player 2', targetPos: 1 }
        ];

        // LADDERS: [start, end]
        const ladders = [
            [4, 25], [13, 46], [33, 49], [42, 63], [50, 69], [62, 81], [74, 92]
        ];

        // SNAKES: [start, end]
        const snakes = [
            [27, 5], [40, 3], [43, 18], [54, 31], [66, 45], [89, 53], [99, 41]
        ];

        function resizeCanvas() {
            const controls = document.querySelector(".controls");
            const controlHeight = controls ? controls.offsetHeight : 150;
            const availableHeight = window.innerHeight - controlHeight - 40;
            const availableWidth = window.innerWidth * 0.95;
            const size = Math.min(availableWidth, availableHeight);
            canvas.width = size;
            canvas.height = size;
            tileSize = size / gridSize;
            drawBoard();
        }

        function getTileCoords(tileNum) {
            let row = Math.floor((tileNum - 1) / gridSize);
            let col = (tileNum - 1) % gridSize;
            
            // Zigzag logic
            if (row % 2 !== 0) {
                col = (gridSize - 1) - col;
            }
            
            const x = col * tileSize;
            const y = (gridSize - 1 - row) * tileSize;
            return { x, y, center: { x: x + tileSize / 2, y: y + tileSize / 2 } };
        }

        function drawBoard() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // Draw Tiles
            for (let i = 1; i <= 100; i++) {
                const { x, y } = getTileCoords(i);
                
                // Color pattern
                ctx.fillStyle = (Math.floor((i-1)/10) + (i-1)%10) % 2 === 0 ? '#dff5e1' : '#fff6d6';
                ctx.strokeStyle = '#333';
                ctx.lineWidth = 1;
                ctx.fillRect(x, y, tileSize, tileSize);
                ctx.strokeRect(x, y, tileSize, tileSize);

                // Numbers
                ctx.fillStyle = 'rgba(0,0,0,0.2)';
                ctx.font = `bold ${tileSize * 0.3}px Arial`;
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText(i, x + tileSize/2, y + tileSize/2);
            }

            // Draw Ladders
            ladders.forEach(([start, end]) => {
                drawLadder(start, end);
            });

            // Draw Snakes
            snakes.forEach(([start, end]) => {
                drawSnake(start, end);
            });

            // Draw Players
            players.forEach((p, idx) => {
                const { center } = getTileCoords(p.pos);
                ctx.beginPath();
                ctx.arc(center.x + (idx * 5 - 2.5), center.y + (idx * 5 - 2.5), tileSize * 0.25, 0, Math.PI * 2);
                ctx.fillStyle = p.color;
                ctx.fill();
                ctx.strokeStyle = 'white';
                ctx.lineWidth = 3;
                ctx.stroke();
                ctx.closePath();
            });
        }

        function drawLadder(start, end) {
            const startCoords = getTileCoords(start).center;
            const endCoords = getTileCoords(end).center;
            
            const width = tileSize * 0.3;
            const angle = Math.atan2(endCoords.y - startCoords.y, endCoords.x - startCoords.x);
            
            ctx.save();
            ctx.strokeStyle = '#8b4513'; // Wood brown
            ctx.lineWidth = 6;
            
            // Side rails
            const dx = Math.cos(angle + Math.PI/2) * width/2;
            const dy = Math.sin(angle + Math.PI/2) * width/2;

            ctx.beginPath();
            ctx.moveTo(startCoords.x + dx, startCoords.y + dy);
            ctx.lineTo(endCoords.x + dx, endCoords.y + dy);
            ctx.stroke();

            ctx.beginPath();
            ctx.moveTo(startCoords.x - dx, startCoords.y - dy);
            ctx.lineTo(endCoords.x - dx, endCoords.y - dy);
            ctx.stroke();

            // Steps
            ctx.lineWidth = 4;
            const dist = Math.sqrt(Math.pow(endCoords.x - startCoords.x, 2) + Math.pow(endCoords.y - startCoords.y, 2));
            const steps = 6;
            for(let i=1; i < steps; i++) {
                const ratio = i / steps;
                const sx = startCoords.x + (endCoords.x - startCoords.x) * ratio;
                const sy = startCoords.y + (endCoords.y - startCoords.y) * ratio;
                ctx.beginPath();
                ctx.moveTo(sx + dx, sy + dy);
                ctx.lineTo(sx - dx, sy - dy);
                ctx.stroke();
            }
            ctx.restore();
        }

        function drawSnake(start, end) {
            const startCoords = getTileCoords(start).center;
            const endCoords = getTileCoords(end).center;
            
            ctx.save();
            ctx.lineWidth = 8;
            ctx.strokeStyle = '#2d5a27'; // Dark Green
            ctx.lineCap = 'round';
            
            // Draw body curve
            ctx.beginPath();
            ctx.moveTo(startCoords.x, startCoords.y);
            
            const cp1x = startCoords.x + (endCoords.x - startCoords.x) * 0.2 + (Math.random()*40-20);
            const cp1y = startCoords.y + (endCoords.y - startCoords.y) * 0.5;
            const cp2x = startCoords.x + (endCoords.x - startCoords.x) * 0.8 + (Math.random()*40-20);
            const cp2y = startCoords.y + (endCoords.y - startCoords.y) * 0.5;

            ctx.bezierCurveTo(cp1x, cp1y, cp2x, cp2y, endCoords.x, endCoords.y);
            ctx.stroke();

            // Head
            ctx.beginPath();
            ctx.fillStyle = '#1e3c1a';
            ctx.arc(startCoords.x, startCoords.y, 10, 0, Math.PI*2);
            ctx.fill();
            
            // Eyes
            ctx.fillStyle = 'red';
            ctx.beginPath();
            ctx.arc(startCoords.x - 3, startCoords.y - 2, 2, 0, Math.PI*2);
            ctx.arc(startCoords.x + 3, startCoords.y - 2, 2, 0, Math.PI*2);
            ctx.fill();

            ctx.restore();
        }

        function setDiceDots(value) {
            diceDisplay.innerHTML = '';
            const dotPositions = {
                1: [[50, 50]],
                2: [[25, 25], [75, 75]],
                3: [[25, 25], [50, 50], [75, 75]],
                4: [[25, 25], [25, 75], [75, 25], [75, 75]],
                5: [[25, 25], [25, 75], [50, 50], [75, 25], [75, 75]],
                6: [[25, 25], [25, 50], [25, 75], [75, 25], [75, 50], [75, 75]]
            };

            dotPositions[value].forEach(([x, y]) => {
                const dot = document.createElement('div');
                dot.className = 'dot';
                dot.style.left = `${x}%`;
                dot.style.top = `${y}%`;
                dot.style.transform = 'translate(-50%, -50%)';
                diceDisplay.appendChild(dot);
            });
        }

        async function movePlayer(playerIndex, steps) {
            isMoving = true;
            rollBtn.disabled = true;
            const p = players[playerIndex];
            
            for (let i = 0; i < steps; i++) {
                if (p.pos < 100) {
                    p.pos++;
                    drawBoard();
                    await new Promise(r => setTimeout(r, 250));
                }
            }

            // Check for ladders or snakes
            let found = false;
            
            const ladder = ladders.find(l => l[0] === p.pos);
            if (ladder) {
                showMessage("Climbed a Ladder! 🪜");
                p.pos = ladder[1];
                found = true;
            }

            const snake = snakes.find(s => s[0] === p.pos);
            if (snake) {
                showMessage("Snake Bite! 🐍");
                p.pos = snake[1];
                found = true;
            }

            if (found) {
                await new Promise(r => setTimeout(r, 500));
                drawBoard();
            }

            if (p.pos === 100) {
                showMessage(`${p.name} Wins! 🎉`);
                rollBtn.disabled = true;
                return;
            }

            currentPlayer = (currentPlayer + 1) % 2;
            updateActivePlayerUI();
            isMoving = false;
            rollBtn.disabled = false;
        }

        function showMessage(text) {
            gameMsg.textContent = text;
            gameMsg.style.display = 'block';
            setTimeout(() => {
                gameMsg.style.display = 'none';
            }, 2000);
        }

        function updateActivePlayerUI() {
            document.getElementById('p1-card').classList.toggle('active', currentPlayer === 0);
            document.getElementById('p2-card').classList.toggle('active', currentPlayer === 1);
        }

        rollBtn.addEventListener('click', () => {
            if (isMoving) return;
            
            diceSound.currentTime = 0;
            diceSound.play().catch(e => console.log("Sound interaction block"));

            let counter = 0;
            const interval = setInterval(() => {
                const val = Math.floor(Math.random() * 6) + 1;
                setDiceDots(val);
                counter++;
                if (counter > 10) {
                    clearInterval(interval);
                    const finalRoll = Math.floor(Math.random() * 6) + 1;
                    setDiceDots(finalRoll);
                    
                    // Logic for exact 100
                    if (players[currentPlayer].pos + finalRoll <= 100) {
                        movePlayer(currentPlayer, finalRoll);
                    } else {
                        showMessage("Too High! Need exact number.");
                        currentPlayer = (currentPlayer + 1) % 2;
                        updateActivePlayerUI();
                    }
                }
            }, 50);
        });

        startBtn.addEventListener('click', () => {
            startScreen.style.opacity = '0';
            setTimeout(() => {
                startScreen.style.display = 'none';
                gameContainer.style.display = 'flex';
                resizeCanvas();
            }, 500);
        });

        window.addEventListener('resize', resizeCanvas);
        
        // Initial setup
        setDiceDots(1);
    </script>
</body>
</html>
